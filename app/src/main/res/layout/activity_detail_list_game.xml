<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:id="@+id/main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgGameDetail"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:layout_gravity="center_horizontal"
                    app:shapeAppearanceOverlay="@style/RoundedImage"/>

                <TextView
                    android:id="@+id/tvNamaGame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Game"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginTop="30dp" />

                <TextView
                    android:id="@+id/tvDeveloper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By: Game Studio"
                    android:textSize="14sp"
                    android:textColor="#666" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tvTipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action • Online"
                        android:textSize="13sp"
                        android:padding="6dp"
                        android:background="@drawable/bg_transparent"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.5"
                        android:textSize="13sp"
                        android:padding="6dp"
                        android:background="@drawable/bg_transparent"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#1 di Play Store"
                    android:textStyle="bold"
                    android:background="@drawable/bg_transparent"
                    android:padding="6dp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tvVersi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Versi: 1.0.0"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvDeskripsiSingkat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Game seru dengan pertarungan real-time dan grafis keren."
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tvDeskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi lengkap game akan ditampilkan di sini. Bisa menjelaskan gameplay, fitur, mode, event, dan lainnya seperti di Play Store."
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/btnInstall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="INSTALL"
                    android:backgroundTint="#1E88E5"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>